{
  "name": "stock-trading-monitor",
  "version": "1.0.0",
  "description": "股票交易监控和提醒系统 - 基于双均线MA策略的实时监控工具",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "watch:summary": "tsx src/cli/watchSummary.ts",
    "test": "vitest --run --pool=forks",
    "test:watch": "vitest --pool=forks",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "trading",
    "stock",
    "crypto",
    "ma-strategy",
    "monitoring"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "express": "^4.18.0",
    "nodemailer": "^6.9.0"
  }
}
